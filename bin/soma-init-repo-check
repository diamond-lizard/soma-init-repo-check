#!/usr/bin/env bash
# Shell wrapper for soma-init-repo-check.
# Resolves symlinks, activates the project venv, and invokes the Python module.
set -euo pipefail

script_path="$(realpath "${BASH_SOURCE[0]}")"
project_root="$(dirname "$(dirname "$script_path")")"

# shellcheck source=/dev/null
source "${project_root}/.venv/bin/activate"

export SOMA_PROG_NAME="$0"
exec python -m soma_init_repo_check "$@"
